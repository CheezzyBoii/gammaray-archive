#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/root/TCP/node_modules/.pnpm/@tomphttp+bare-server-node@2.0.6_bufferutil@4.0.9/node_modules/@tomphttp/bare-server-node/node_modules:/root/TCP/node_modules/.pnpm/@tomphttp+bare-server-node@2.0.6_bufferutil@4.0.9/node_modules:/root/TCP/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/root/TCP/node_modules/.pnpm/@tomphttp+bare-server-node@2.0.6_bufferutil@4.0.9/node_modules/@tomphttp/bare-server-node/node_modules:/root/TCP/node_modules/.pnpm/@tomphttp+bare-server-node@2.0.6_bufferutil@4.0.9/node_modules:/root/TCP/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../@tomphttp+bare-server-node@2.0.6_bufferutil@4.0.9/node_modules/@tomphttp/bare-server-node/bin.js" "$@"
else
  exec node  "$basedir/../../../../../@tomphttp+bare-server-node@2.0.6_bufferutil@4.0.9/node_modules/@tomphttp/bare-server-node/bin.js" "$@"
fi
